rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdminEmail() {
      return signedIn() && request.auth.token.email in [
        "thanks.gigatt@gmail.com"
      ];
    }

    function isAdmin() {
      return isAdminEmail()
        || (
          signedIn()
          && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid))
          && get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == "admin"
        );
    }

    function isBlocked(uid) {
      return exists(/databases/$(database)/documents/userProfiles/$(uid))
        && get(/databases/$(database)/documents/userProfiles/$(uid)).data.status == "blocked";
    }

    function canUseOwnData(uid) {
      return isOwner(uid) && !isBlocked(uid);
    }

    function isRoutineType(routineType) {
      return routineType == "health" || routineType == "growth";
    }

    function isUsableStatus(status) {
      return status == "active" || status == "approved" || status == "pending";
    }

    function validOwnRole(role) {
      return (isAdminEmail() && role == "admin") || (!isAdminEmail() && role == "user");
    }

    match /userProfiles/{uid} {
      allow read: if isAdmin() || isOwner(uid);
      allow create: if isAdmin()
        || (isOwner(uid)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.email == request.auth.token.email
          && validOwnRole(request.resource.data.role)
          && isUsableStatus(request.resource.data.status));
      allow update: if isAdmin()
        || (isOwner(uid)
          && !isBlocked(uid)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.email == request.auth.token.email
          && (
            request.resource.data.role == resource.data.role
            || (resource.data.role == null && validOwnRole(request.resource.data.role))
          )
          && (
            request.resource.data.status == resource.data.status
            || (resource.data.status == null && isUsableStatus(request.resource.data.status))
          ));
      allow delete: if isAdmin();
    }

    match /userRoutines/{uid}/days/{dayId} {
      allow read, write: if isAdmin() || canUseOwnData(uid);
    }

    match /userRoutines/{uid}/types/{routineType}/days/{dayId} {
      allow read, write: if isRoutineType(routineType)
        && (isAdmin() || canUseOwnData(uid));
    }

    match /userRoutineRecords/{uid}/records/{date} {
      allow read, write: if isAdmin() || canUseOwnData(uid);
    }

    match /userRoutineRecords/{uid}/types/{routineType}/records/{date} {
      allow read, write: if isRoutineType(routineType)
        && (isAdmin() || canUseOwnData(uid));
    }
  }
}
