rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.email in [
          "thanks.gigatt@gmail.com"
        ]
        || (
          exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid))
          && get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == "admin"
          && get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.status == "approved"
        )
      );
    }

    function isApproved(uid) {
      return exists(/databases/$(database)/documents/userProfiles/$(uid))
        && get(/databases/$(database)/documents/userProfiles/$(uid)).data.status == "approved";
    }

    function canUseOwnData(uid) {
      return isOwner(uid) && isApproved(uid);
    }

    function isRoutineType(routineType) {
      return routineType == "health" || routineType == "growth";
    }

    function isLegacyProfileMigration(uid) {
      return isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && resource.data.status == null
        && request.resource.data.role == "user"
        && request.resource.data.status == "pending";
    }

    match /userProfiles/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isAdmin()
        || (isOwner(uid)
          && request.auth.token.email in [
            "thanks.gigatt@gmail.com"
          ]
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.role == "admin"
          && request.resource.data.status == "approved")
        || (isOwner(uid)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.role == "user"
          && request.resource.data.status == "pending");
      allow update: if isAdmin()
        || isLegacyProfileMigration(uid)
        || (isOwner(uid)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.status == resource.data.status);
      allow delete: if isAdmin();
    }

    match /userRoutines/{uid}/days/{dayId} {
      allow read: if isAdmin() || (isOwner(uid) && isApproved(uid));
      allow create, update: if isAdmin()
        || (isOwner(uid)
          && isApproved(uid)
          && request.resource.data.dayId == dayId);
      allow delete: if isAdmin();
    }

    match /userRoutines/{uid}/types/{routineType}/days/{dayId} {
      allow read: if isRoutineType(routineType)
        && (isAdmin() || canUseOwnData(uid));
      allow create, update: if isRoutineType(routineType)
        && (isAdmin() || canUseOwnData(uid));
      allow delete: if isAdmin() && isRoutineType(routineType);
    }

    match /userRoutineRecords/{uid}/records/{date} {
      allow read: if isAdmin() || (isOwner(uid) && isApproved(uid));
      allow create, update: if isAdmin()
        || (isOwner(uid)
          && isApproved(uid)
          && request.resource.data.uid == request.auth.uid);
      allow delete: if isAdmin() || (isOwner(uid) && isApproved(uid));
    }

    match /userRoutineRecords/{uid}/types/{routineType}/records/{date} {
      allow read: if isRoutineType(routineType)
        && (isAdmin() || canUseOwnData(uid));
      allow create, update: if isRoutineType(routineType)
        && (isAdmin() || canUseOwnData(uid));
      allow delete: if isRoutineType(routineType)
        && (isAdmin() || canUseOwnData(uid));
    }
  }
}
